{
  "manifest_version": 3,
  "name": "LAVA — Level Access Validation Assistant",
  "version": "2.0.0",
  "description": "Manage accessibility validation projects end-to-end: import findings, validate, generate reports.",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "windows"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/lava-icon-16.png",
    "32":  "icons/lava-icon-32.png",
    "48":  "icons/lava-icon-48.png",
    "128": "icons/lava-icon-128.png"
  },
  "action": {
    "default_title": "LAVA",
    "default_icon": {
      "16":  "icons/lava-icon-16.png",
      "32":  "icons/lava-icon-32.png",
      "48":  "icons/lava-icon-48.png",
      "128": "icons/lava-icon-128.png"
    }
  }
}
